{
  "name": "backend",
  "version": "1.0.0",
  "description": "Mini Fintech Platform API with Hexagonal Architecture",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typeorm": "typeorm",
    "migration:generate": "typeorm migration:generate -d dist/infrastructure/persistence/data-source.js",
    "migration:run": "typeorm migration:run -d dist/infrastructure/persistence/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/infrastructure/persistence/data-source.js"
  },
  "keywords": [
    "fintech",
    "hexagonal-architecture",
    "fastify",
    "typeorm"
  ],
  "author": "André Malpica",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "awilix": "^13.0.3",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
